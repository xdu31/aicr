# AICR Development Environment Setup
#
# This script installs all required dependencies for development
# on Linux (x86_64/arm64) and macOS (amd64/arm64).
#
# Usage:
#   ./tools/setup-tools                    # Interactive mode
#   ./tools/setup-tools --auto             # Non-interactive mode
#   ./tools/setup-tools --skip-go          # Skip Go installation check
#   ./tools/setup-tools --skip-docker      # Skip Docker check
#   ./tools/setup-tools --skip-tools       # Skip development tools installation
#   ./tools/setup-tools --help             # Show help

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=tools/common
. "${DIR}/common"
VERSIONS_FILE="${REPO_ROOT}/.settings.yaml"

# Configuration
AUTO_MODE=${AUTO_MODE:-false}
SKIP_GO=false
SKIP_DOCKER=false
SKIP_TOOLS=false
UPGRADE=false

# Detect OS and architecture
OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)

# Map architecture names for different tools
case "${ARCH}" in
    x86_64)
        GO_ARCH="amd64"
        ;;
    aarch64|arm64)
        GO_ARCH="arm64"
        ARCH="arm64"  # Normalize to arm64
        ;;
    *) echo -e "${RED}❌ Unsupported architecture: ${ARCH}${NC}" && exit 1 ;;
esac

# Verify URL accessibility before downloading
verify_download_url() {
    local url="$1"
    local description="$2"

    log_debug "Attempting to verify: $description"
    log_debug "URL: $url"

    local http_code
    http_code=$(curl -f -s -I -L -w "%{http_code}" -o /dev/null "$url" 2>/dev/null)
    local curl_exit_code=$?

    if [[ $curl_exit_code -ne 0 || "$http_code" != "200" ]]; then
        log_error "Failed to access URL for $description"
        log_error "URL: $url"
        log_error "HTTP status code: ${http_code:-unknown}"

        if [[ "$http_code" == "404" ]]; then
            log_error "File not found (404). The version or architecture might not be available."
        elif [[ "$http_code" == "403" ]]; then
            log_error "Access forbidden (403). This might be a rate limit issue."
        elif [[ $curl_exit_code -eq 6 ]]; then
            log_error "Could not resolve host. Check your internet connection."
        fi

        return 1
    fi

    log_debug "URL verified successfully for $description (HTTP $http_code)"
    return 0
}

verify_sha256() {
    local file_path="$1"
    local expected_sha="$2"

    if [[ -z "$expected_sha" || "$expected_sha" == "SKIP" ]]; then
        return 0
    fi

    if ! command_exists shasum; then
        log_warning "shasum not available; skipping checksum verification for $file_path"
        return 0
    fi

    local actual_sha
    actual_sha=$(shasum -a 256 "$file_path" | awk '{print $1}')
    if [[ "$actual_sha" != "$expected_sha" ]]; then
        log_error "Checksum mismatch for $file_path"
        log_error "Expected: $expected_sha"
        log_error "Actual:   $actual_sha"
        exit 1
    fi
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

prompt_continue() {
    if [[ "${AUTO_MODE}" == "true" ]]; then
        return 0
    fi

    read -p "Continue? [Y/n] " -r
    REPLY=${REPLY:-Y}
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_warning "Skipped"
        return 1
    fi
    return 0
}

show_help() {
    cat << EOF
AICR Development Environment Setup

Usage: $0 [OPTIONS]

OPTIONS:
    --auto              Non-interactive mode (auto-yes to all prompts)
    --upgrade           Reinstall/upgrade tools to versions in .settings.yaml (default: skip if already installed)
    --skip-go           Skip Go installation check
    --skip-docker       Skip Docker installation check
    --skip-tools        Skip development tools installation
    --help              Show this help message

ENVIRONMENT VARIABLES:
    AUTO_MODE=true      Same as --auto flag (non-interactive mode)
    DEBUG=true          Enable debug output (shows URLs, architecture mappings)

EXAMPLES:
    # Interactive mode
    $0

    # Automated CI setup
    $0 --auto

    # Upgrade all tools to .settings.yaml (e.g. make tools-update)
    $0 --upgrade --auto

    # Install only tools (Go already installed)
    $0 --skip-go --skip-docker

    # Enable debug output to troubleshoot download issues
    DEBUG=true $0

EOF
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --auto)
            AUTO_MODE=true
            shift
            ;;
        --skip-go)
            SKIP_GO=true
            shift
            ;;
        --skip-docker)
            SKIP_DOCKER=true
            shift
            ;;
        --skip-tools)
            SKIP_TOOLS=true
            shift
            ;;
        --upgrade)
            UPGRADE=true
            shift
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            show_help
            exit 1
            ;;
    esac
done

# Banner
echo ""
echo "╔════════════════════════════════════════════════════════╗"
echo "║   AICR Development Environment Setup                  ║"
echo "╚════════════════════════════════════════════════════════╝"
echo ""
log_info "Platform: ${OS}-${GO_ARCH}"
log_debug "Architecture: ${ARCH} -> GO_ARCH=${GO_ARCH}"
echo ""

# Check if .settings.yaml exists
if [[ ! -f "${VERSIONS_FILE}" ]]; then
    log_error "Version file not found: ${VERSIONS_FILE}"
    log_error "Please run this script from the repository root or ensure .settings.yaml exists"
    exit 1
fi

# is_mikefarah_yq returns 0 if the installed yq is mikefarah/yq (Go-based).
# Python-based yq (pip) wraps jq and outputs JSON-quoted strings, breaking
# version parsing throughout this script and the broader toolchain.
is_mikefarah_yq() {
    yq --version 2>/dev/null | grep -q "mikefarah/yq"
}

# Fail fast if the wrong yq variant is installed.
if command_exists yq && ! is_mikefarah_yq; then
    log_error "Found Python-based yq at $(which yq)."
    log_error "This project requires mikefarah/yq (Go-based)."
    log_error "Please remove it first:  pip uninstall yq  (or:  sudo apt remove yq)"
    log_error "Then re-run:  make tools-setup"
    exit 1
fi

# Install yq if not present or --upgrade (needed to parse .settings.yaml)
if ! command_exists yq || [[ "${UPGRADE}" == "true" ]]; then
    if command_exists yq && [[ "${UPGRADE}" == "true" ]]; then
        log_info "Upgrading yq (YAML processor)..."
    else
        log_info "Installing yq (YAML processor)..."
    fi

    if [[ "${OS}" == "darwin" ]]; then
        if command_exists brew; then
            brew install yq
        else
            log_error "Homebrew not found. Please install Homebrew first: https://brew.sh"
            exit 1
        fi
    elif [[ "${OS}" == "linux" ]]; then
        YQ_URL="https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${GO_ARCH}"

        if verify_download_url "$YQ_URL" "yq for Linux ${GO_ARCH}"; then
            log_debug "Downloading yq from: $YQ_URL"
            sudo curl -fsSL "$YQ_URL" -o /usr/local/bin/yq
            sudo chmod +x /usr/local/bin/yq
        else
            log_error "Failed to install yq. Please install manually."
            exit 1
        fi
    fi

    log_success "yq installed"
else
    log_success "yq already installed: $(yq --version)"
fi

# Load versions from .settings.yaml
log_info "Loading versions from .settings.yaml..."
cd "${REPO_ROOT}"

GO_VERSION=$(yq '.languages.go' .settings.yaml)
GOLANGCI_LINT_VERSION=$(yq '.linting.golangci_lint' .settings.yaml)
YAMLLINT_VERSION=$(yq '.linting.yamllint' .settings.yaml)
ADDLICENSE_VERSION=$(yq '.linting.addlicense' .settings.yaml)
GO_LICENSES_VERSION=$(yq '.linting.go_licenses' .settings.yaml)
GRYPE_VERSION=$(yq '.security_tools.grype' .settings.yaml)
COSIGN_VERSION=$(yq '.security_tools.cosign' .settings.yaml)
SYFT_VERSION=$(yq '.security_tools.syft' .settings.yaml)
KIND_VERSION=$(yq '.testing_tools.kind' .settings.yaml)
KUBECTL_VERSION=$(yq '.testing_tools.kubectl' .settings.yaml)
CTLPTL_VERSION=$(yq '.testing_tools.ctlptl' .settings.yaml)
TILT_VERSION=$(yq '.testing_tools.tilt' .settings.yaml)
HELM_VERSION=$(yq '.testing_tools.helm' .settings.yaml)
CHAINSAW_VERSION=$(yq '.testing_tools.chainsaw' .settings.yaml)
KO_VERSION=$(yq '.build_tools.ko' .settings.yaml)
CRANE_VERSION=$(yq '.build_tools.crane' .settings.yaml)
GORELEASER_VERSION=$(yq '.build_tools.goreleaser' .settings.yaml)
GIT_CLIFF_VERSION=$(yq '.build_tools.git_cliff' .settings.yaml)

echo ""
log_info "Target Versions:"
echo "  Go:              ${GO_VERSION}"
echo "  golangci-lint:   ${GOLANGCI_LINT_VERSION}"
echo "  grype:           ${GRYPE_VERSION}"
echo "  cosign:          ${COSIGN_VERSION}"
echo "  syft:            ${SYFT_VERSION}"
echo "  kind:            ${KIND_VERSION}"
echo "  kubectl:         ${KUBECTL_VERSION}"
echo "  tilt:            ${TILT_VERSION}"
echo "  helm:            ${HELM_VERSION}"
echo "  chainsaw:        ${CHAINSAW_VERSION}"
echo "  goreleaser:      ${GORELEASER_VERSION}"
echo "  git-cliff:       ${GIT_CLIFF_VERSION}"
echo ""

# ============================================================================
# Go Installation Check
# ============================================================================
if [[ "${SKIP_GO}" == "false" ]]; then
    echo "════════════════════════════════════════════════════════"
    log_info "Go Installation"
    echo "════════════════════════════════════════════════════════"

    if command_exists go; then
        CURRENT_GO=$(go version | grep -o 'go[0-9]\+\.[0-9]\+\(\.[0-9]\+\)\?' | sed 's/go//' || echo "unknown")
        log_info "Current Go version: ${CURRENT_GO}"

        if [[ "${CURRENT_GO}" == "${GO_VERSION}"* ]]; then
            log_success "Go ${GO_VERSION} already installed"
        else
            log_warning "Go version mismatch (current: ${CURRENT_GO}, target: ${GO_VERSION})"
            log_info "Please install Go ${GO_VERSION} from https://go.dev/dl/"
        fi
    else
        log_warning "Go not found"
        log_info "Please install Go ${GO_VERSION} from https://go.dev/dl/"
    fi
    echo ""
fi

# ============================================================================
# Docker Check
# ============================================================================
if [[ "${SKIP_DOCKER}" == "false" ]]; then
    echo "════════════════════════════════════════════════════════"
    log_info "Docker Check"
    echo "════════════════════════════════════════════════════════"

    if command_exists docker; then
        if docker info >/dev/null 2>&1; then
            DOCKER_VERSION=$(docker version --format '{{.Server.Version}}')
            log_success "Docker is installed and running: ${DOCKER_VERSION}"
        else
            log_warning "Docker is installed but not running"
            log_info "Please start Docker Desktop or the Docker daemon"
        fi
    else
        log_warning "Docker not found"
        log_info "Please install Docker: https://docs.docker.com/get-docker/"
    fi
    echo ""
fi

# ============================================================================
# Development Tools Installation
# ============================================================================
if [[ "${SKIP_TOOLS}" == "false" ]]; then
    echo "════════════════════════════════════════════════════════"
    log_info "Development Tools Installation"
    echo "════════════════════════════════════════════════════════"

    GRYPE_INSTALL_SHA256=${GRYPE_INSTALL_SHA256:-"8646f06a90b10ca64992c1809b4aa00c44e30b4f551f63c309b0b0ab66873556"}
    GOLANGCI_LINT_INSTALL_SHA256=${GOLANGCI_LINT_INSTALL_SHA256:-"d32d3534af96cfd59546a084d22b213e8a47541cada5013aa8a84c4fa2589905"}

    if command_exists helm && [[ "${UPGRADE}" != "true" ]]; then
        log_success "Helm already installed: $(helm version --short)"
    else
        log_info "Installing Helm ${HELM_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install helm
            elif [[ "${OS}" == "linux" ]]; then
                HELM_TMP=$(mktemp -d)
                HELM_TAR="helm-${HELM_VERSION}-linux-${GO_ARCH}.tar.gz"
                HELM_URL="https://get.helm.sh/${HELM_TAR}"
                if verify_download_url "$HELM_URL" "helm ${HELM_VERSION} for Linux ${GO_ARCH}"; then
                    curl -fsSL "$HELM_URL" | tar -xzC "$HELM_TMP"
                    sudo mv "$HELM_TMP/linux-${GO_ARCH}/helm" /usr/local/bin/helm
                    sudo chmod +x /usr/local/bin/helm
                    rm -rf "$HELM_TMP"
                else
                    log_error "Failed to install helm. Please install manually."
                    rm -rf "$HELM_TMP"
                fi
            fi
            log_success "Helm installed"
        fi
    fi

    # chainsaw (declarative e2e testing)
    if command_exists chainsaw && [[ "${UPGRADE}" != "true" ]]; then
        log_success "Chainsaw already installed: $(chainsaw version 2>/dev/null | head -1)"
    else
        log_info "Installing Chainsaw ${CHAINSAW_VERSION}..."
        if prompt_continue; then
            CHAINSAW_VER="${CHAINSAW_VERSION#v}"
            CHAINSAW_OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
            CHAINSAW_ARCH="$(uname -m)"
            case "${CHAINSAW_ARCH}" in
                x86_64) CHAINSAW_ARCH="amd64" ;;
                aarch64|arm64) CHAINSAW_ARCH="arm64" ;;
            esac
            CHAINSAW_TAR="chainsaw_${CHAINSAW_OS}_${CHAINSAW_ARCH}.tar.gz"
            CHAINSAW_URL="https://github.com/kyverno/chainsaw/releases/download/v${CHAINSAW_VER}/${CHAINSAW_TAR}"
            CHAINSAW_SHA256=$(yq ".testing_tools.chainsaw_checksums.${CHAINSAW_OS}_${CHAINSAW_ARCH}" .settings.yaml)
            CHAINSAW_TMP="$(mktemp -d)"
            curl -fsSL -o "${CHAINSAW_TMP}/${CHAINSAW_TAR}" "${CHAINSAW_URL}"
            verify_sha256 "${CHAINSAW_TMP}/${CHAINSAW_TAR}" "${CHAINSAW_SHA256}"
            tar -xzf "${CHAINSAW_TMP}/${CHAINSAW_TAR}" -C "${CHAINSAW_TMP}"
            sudo mv "${CHAINSAW_TMP}/chainsaw" /usr/local/bin/chainsaw
            sudo chmod +x /usr/local/bin/chainsaw
            rm -rf "${CHAINSAW_TMP}"
            log_success "Chainsaw installed"
        fi
    fi

    # kubectl
    if command_exists kubectl && [[ "${UPGRADE}" != "true" ]]; then
        log_success "kubectl already installed: $(kubectl version --client --short 2>/dev/null || kubectl version --client)"
    else
        log_info "Installing kubectl ${KUBECTL_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install kubectl
            elif [[ "${OS}" == "linux" ]]; then
                KUBECTL_URL="https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/${GO_ARCH}/kubectl"

                if verify_download_url "$KUBECTL_URL" "kubectl ${KUBECTL_VERSION} for Linux ${GO_ARCH}"; then
                    sudo curl -fsSL "$KUBECTL_URL" -o /usr/local/bin/kubectl
                    sudo chmod +x /usr/local/bin/kubectl
                else
                    log_error "Failed to install kubectl. Please install manually."
                    exit 1
                fi
            fi
            log_success "kubectl ${KUBECTL_VERSION} installed"
        fi
    fi

    # yamllint (for YAML linting)
    if command_exists yamllint && [[ "${UPGRADE}" != "true" ]]; then
        log_success "yamllint already installed: $(yamllint --version)"
    else
        log_info "Installing yamllint..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install yamllint
            elif [[ "${OS}" == "linux" ]]; then
                if ! command_exists python3; then
                    log_warning "python3 not found; skipping yamllint install"
                elif ! grep -qiE 'ubuntu|debian' /etc/os-release 2>/dev/null; then
                    echo ""
                    log_warning "================================================================"
                    log_warning "yamllint auto-install is only supported on Debian/Ubuntu."
                    log_warning "Please install yamllint ${YAMLLINT_VERSION} manually:"
                    log_warning "  pip install yamllint==${YAMLLINT_VERSION}"
                    log_warning "================================================================"
                    echo ""
                else
                    # Ensure python3-venv is available
                    if ! python3 -c "import ensurepip" &>/dev/null; then
                        PY_VER=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
                        log_info "Installing python${PY_VER}-venv..."
                        sudo apt-get install -y "python${PY_VER}-venv" 2>/dev/null \
                            || sudo apt-get install -y python3-venv
                    fi
                    YAMLLINT_VENV="/opt/aicr/yamllint"
                    sudo mkdir -p /opt/aicr
                    sudo python3 -m venv "$YAMLLINT_VENV"
                    sudo "$YAMLLINT_VENV/bin/pip" install "yamllint==${YAMLLINT_VERSION}"
                    sudo ln -sf "$YAMLLINT_VENV/bin/yamllint" /usr/local/bin/yamllint
                fi
            fi
            log_success "yamllint installed"
        fi
    fi

    # grype (vulnerability scanner)
    if command_exists grype && [[ "${UPGRADE}" != "true" ]]; then
        log_success "grype already installed: $(grype version 2>/dev/null | head -1)"
    else
        log_info "Installing grype ${GRYPE_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install grype
            elif [[ "${OS}" == "linux" ]]; then
                GRYPE_SCRIPT_URL="https://raw.githubusercontent.com/anchore/grype/main/install.sh"
                GRYPE_TMP=$(mktemp -d)
                curl -fsSL "$GRYPE_SCRIPT_URL" -o "$GRYPE_TMP/install.sh"
                verify_sha256 "$GRYPE_TMP/install.sh" "${GRYPE_INSTALL_SHA256:-SKIP}"
                # The anchore install.sh queries github.com for release metadata,
                # which intermittently 502s. Retry with quadratic backoff so a brief
                # CDN blip does not fail the whole CI step.
                grype_attempt=0
                grype_max_attempts=3
                until sh "$GRYPE_TMP/install.sh" -b "$GRYPE_TMP" "${GRYPE_VERSION}"; do
                    grype_attempt=$((grype_attempt + 1))
                    if [[ ${grype_attempt} -ge ${grype_max_attempts} ]]; then
                        log_error "grype install failed after ${grype_max_attempts} attempts"
                        rm -rf "$GRYPE_TMP"
                        exit 1
                    fi
                    grype_delay=$((grype_attempt * grype_attempt * 5))
                    log_warning "grype install attempt ${grype_attempt} failed (likely transient github.com 502); retrying in ${grype_delay}s"
                    sleep "${grype_delay}"
                done
                sudo mv "$GRYPE_TMP/grype" /usr/local/bin/grype
                sudo chmod +x /usr/local/bin/grype
                rm -rf "$GRYPE_TMP"
            fi
            log_success "grype installed"
        fi
    fi

    # cosign (Sigstore signing and verification)
    if command_exists cosign && [[ "${UPGRADE}" != "true" ]]; then
        log_success "cosign already installed: $(cosign version 2>/dev/null | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' | head -1)"
    else
        log_info "Installing cosign ${COSIGN_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install cosign
            elif [[ "${OS}" == "linux" ]]; then
                COSIGN_VER="${COSIGN_VERSION#v}"
                COSIGN_URL="https://github.com/sigstore/cosign/releases/download/v${COSIGN_VER}/cosign-linux-${GO_ARCH}"
                if verify_download_url "$COSIGN_URL" "cosign ${COSIGN_VERSION} for Linux ${GO_ARCH}"; then
                    sudo curl -fsSL "$COSIGN_URL" -o /usr/local/bin/cosign
                    sudo chmod +x /usr/local/bin/cosign
                else
                    log_error "Failed to install cosign. Please install manually."
                fi
            fi
            log_success "cosign installed"
        fi
    fi

    # syft (SBOM generator)
    if command_exists syft && [[ "${UPGRADE}" != "true" ]]; then
        log_success "syft already installed: $(syft version 2>/dev/null | grep -E '^Version:' | awk '{print $2}')"
    else
        log_info "Installing syft ${SYFT_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install syft
            elif [[ "${OS}" == "linux" ]]; then
                SYFT_VER="${SYFT_VERSION#v}"
                SYFT_TMP=$(mktemp -d)
                SYFT_URL="https://github.com/anchore/syft/releases/download/v${SYFT_VER}/syft_${SYFT_VER}_linux_${GO_ARCH}.tar.gz"
                if verify_download_url "$SYFT_URL" "syft ${SYFT_VERSION} for Linux ${GO_ARCH}"; then
                    curl -fsSL "$SYFT_URL" | tar -xzC "$SYFT_TMP"
                    sudo mv "$SYFT_TMP/syft" /usr/local/bin/syft
                    sudo chmod +x /usr/local/bin/syft
                    rm -rf "$SYFT_TMP"
                else
                    log_error "Failed to install syft. Please install manually."
                    rm -rf "$SYFT_TMP"
                fi
            fi
            log_success "syft installed"
        fi
    fi

    # Tilt
    if command_exists tilt && [[ "${UPGRADE}" != "true" ]]; then
        log_success "Tilt already installed: $(tilt version)"
    else
        log_info "Installing Tilt ${TILT_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install tilt
            elif [[ "${OS}" == "linux" ]]; then
                # Install to a temp directory first to avoid "file exists" errors
                TILT_TMP=$(mktemp -d)
                TILT_URL="https://github.com/tilt-dev/tilt/releases/download/v${TILT_VERSION}/tilt.${TILT_VERSION}.linux.x86_64.tar.gz"
                if [[ "${GO_ARCH}" == "arm64" ]]; then
                    TILT_URL="https://github.com/tilt-dev/tilt/releases/download/v${TILT_VERSION}/tilt.${TILT_VERSION}.linux.arm64.tar.gz"
                fi
                if verify_download_url "$TILT_URL" "tilt ${TILT_VERSION} for Linux ${GO_ARCH}"; then
                    curl -fsSL "$TILT_URL" | tar -xzC "$TILT_TMP"
                    sudo mv "$TILT_TMP/tilt" /usr/local/bin/tilt
                    sudo chmod +x /usr/local/bin/tilt
                    rm -rf "$TILT_TMP"
                else
                    log_error "Failed to install Tilt. Please install manually."
                    rm -rf "$TILT_TMP"
                fi
            fi
            log_success "Tilt installed"
        fi
    fi

    # Kind
    if command_exists kind && [[ "${UPGRADE}" != "true" ]]; then
        log_success "Kind already installed: $(kind version)"
    else
        log_info "Installing Kind ${KIND_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install kind
            elif [[ "${OS}" == "linux" ]]; then
                KIND_URL="https://kind.sigs.k8s.io/dl/v${KIND_VERSION}/kind-linux-${GO_ARCH}"
                if verify_download_url "$KIND_URL" "kind ${KIND_VERSION} for Linux ${GO_ARCH}"; then
                    sudo curl -Lo /usr/local/bin/kind "$KIND_URL"
                    sudo chmod +x /usr/local/bin/kind
                else
                    log_error "Failed to install kind. Please install manually."
                fi
            fi
            log_success "Kind installed"
        fi
    fi

    # ctlptl
    if command_exists ctlptl && [[ "${UPGRADE}" != "true" ]]; then
        log_success "ctlptl already installed: $(ctlptl version)"
    else
        log_info "Installing ctlptl ${CTLPTL_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install tilt-dev/tap/ctlptl
            elif [[ "${OS}" == "linux" ]]; then
                if command_exists go; then
                    go install github.com/tilt-dev/ctlptl/cmd/ctlptl@v"${CTLPTL_VERSION}"
                    sudo cp "$(go env GOPATH)/bin/ctlptl" /usr/local/bin/
                else
                    log_warning "Go not installed, skipping ctlptl"
                fi
            fi
            log_success "ctlptl installed"
        fi
    fi

    # ko (container image builder)
    if command_exists ko && [[ "${UPGRADE}" != "true" ]]; then
        log_success "ko already installed: $(ko version)"
    else
        log_info "Installing ko ${KO_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install ko
            elif [[ "${OS}" == "linux" ]]; then
                # Install from binary release (go install has module path issues)
                # Strip 'v' prefix for URL construction (version in .settings.yaml includes 'v')
                KO_VERSION_NUM="${KO_VERSION#v}"
                KO_TMP=$(mktemp -d)
                KO_URL="https://github.com/ko-build/ko/releases/download/v${KO_VERSION_NUM}/ko_${KO_VERSION_NUM}_Linux_x86_64.tar.gz"
                if [[ "${GO_ARCH}" == "arm64" ]]; then
                    KO_URL="https://github.com/ko-build/ko/releases/download/v${KO_VERSION_NUM}/ko_${KO_VERSION_NUM}_Linux_arm64.tar.gz"
                fi
                if verify_download_url "$KO_URL" "ko ${KO_VERSION} for Linux ${GO_ARCH}"; then
                    curl -fsSL "$KO_URL" | tar -xzC "$KO_TMP"
                    sudo mv "$KO_TMP/ko" /usr/local/bin/ko
                    sudo chmod +x /usr/local/bin/ko
                    rm -rf "$KO_TMP"
                else
                    log_error "Failed to install ko. Please install manually."
                    rm -rf "$KO_TMP"
                fi
            fi
            log_success "ko installed"
        fi
    fi

    # crane (container image tool)
    if command_exists crane && [[ "${UPGRADE}" != "true" ]]; then
        log_success "crane already installed: $(crane version 2>/dev/null)"
    else
        log_info "Installing crane ${CRANE_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install crane
            elif [[ "${OS}" == "linux" ]]; then
                CRANE_VER="${CRANE_VERSION#v}"
                CRANE_TMP=$(mktemp -d)
                CRANE_URL="https://github.com/google/go-containerregistry/releases/download/v${CRANE_VER}/go-containerregistry_Linux_x86_64.tar.gz"
                if [[ "${GO_ARCH}" == "arm64" ]]; then
                    CRANE_URL="https://github.com/google/go-containerregistry/releases/download/v${CRANE_VER}/go-containerregistry_Linux_arm64.tar.gz"
                fi
                if verify_download_url "$CRANE_URL" "crane ${CRANE_VERSION} for Linux ${GO_ARCH}"; then
                    curl -fsSL "$CRANE_URL" | tar -xzC "$CRANE_TMP"
                    sudo mv "$CRANE_TMP/crane" /usr/local/bin/crane
                    sudo chmod +x /usr/local/bin/crane
                    rm -rf "$CRANE_TMP"
                else
                    log_error "Failed to install crane. Please install manually."
                    rm -rf "$CRANE_TMP"
                fi
            fi
            log_success "crane installed"
        fi
    fi

    # goreleaser
    if command_exists goreleaser && [[ "${UPGRADE}" != "true" ]]; then
        log_success "goreleaser already installed: $(goreleaser --version 2>/dev/null | sed -n 's/^GitVersion:[[:space:]]*//p')"
    else
        log_info "Installing goreleaser ${GORELEASER_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install goreleaser
            elif [[ "${OS}" == "linux" ]]; then
                if command_exists go; then
                    go install github.com/goreleaser/goreleaser/v2@"${GORELEASER_VERSION}"
                    sudo cp "$(go env GOPATH)/bin/goreleaser" /usr/local/bin/
                else
                    log_warning "Go not installed, skipping goreleaser"
                fi
            fi
            log_success "goreleaser installed"
        fi
    fi

    # git-cliff (changelog generator)
    if command_exists git-cliff && [[ "${UPGRADE}" != "true" ]]; then
        log_success "git-cliff already installed: $(git-cliff --version 2>/dev/null | awk '{print $2}')"
    else
        log_info "Installing git-cliff ${GIT_CLIFF_VERSION}..."
        if prompt_continue; then
            if [[ "${OS}" == "darwin" ]]; then
                brew install git-cliff
            elif [[ "${OS}" == "linux" ]]; then
                GIT_CLIFF_TMP=$(mktemp -d)
                GIT_CLIFF_URL="https://github.com/orhun/git-cliff/releases/download/v${GIT_CLIFF_VERSION}/git-cliff-${GIT_CLIFF_VERSION}-x86_64-unknown-linux-gnu.tar.gz"
                if [[ "${GO_ARCH}" == "arm64" ]]; then
                    GIT_CLIFF_URL="https://github.com/orhun/git-cliff/releases/download/v${GIT_CLIFF_VERSION}/git-cliff-${GIT_CLIFF_VERSION}-aarch64-unknown-linux-gnu.tar.gz"
                fi
                if verify_download_url "$GIT_CLIFF_URL" "git-cliff ${GIT_CLIFF_VERSION} for Linux ${GO_ARCH}"; then
                    curl -fsSL "$GIT_CLIFF_URL" | tar -xzC "$GIT_CLIFF_TMP"
                    sudo mv "$GIT_CLIFF_TMP/git-cliff-${GIT_CLIFF_VERSION}"*/git-cliff /usr/local/bin/git-cliff
                    sudo chmod +x /usr/local/bin/git-cliff
                    rm -rf "$GIT_CLIFF_TMP"
                else
                    log_error "Failed to install git-cliff. Please install manually."
                    rm -rf "$GIT_CLIFF_TMP"
                fi
            fi
            log_success "git-cliff installed"
        fi
    fi

    echo ""
fi

# ============================================================================
# Go Development Tools
# ============================================================================
if [[ "${SKIP_TOOLS}" == "false" ]] && command_exists go; then
    echo "════════════════════════════════════════════════════════"
    log_info "Go Development Tools"
    echo "════════════════════════════════════════════════════════"

    # golangci-lint
    if command_exists golangci-lint && [[ "${UPGRADE}" != "true" ]]; then
        CURRENT_LINT=$(golangci-lint version 2>/dev/null | awk '{print $4}' || echo "unknown")
        log_success "golangci-lint already installed: ${CURRENT_LINT}"
    else
        log_info "Installing golangci-lint ${GOLANGCI_LINT_VERSION}..."
        if prompt_continue; then
            GOLANGCI_SCRIPT_URL="https://raw.githubusercontent.com/golangci/golangci-lint/${GOLANGCI_LINT_VERSION}/install.sh"
            GOLANGCI_TMP=$(mktemp)
            curl -fsSL "$GOLANGCI_SCRIPT_URL" -o "$GOLANGCI_TMP"
            verify_sha256 "$GOLANGCI_TMP" "${GOLANGCI_LINT_INSTALL_SHA256:-SKIP}"
            sh "$GOLANGCI_TMP" -b "$(go env GOPATH)/bin" "${GOLANGCI_LINT_VERSION}"
            rm -f "$GOLANGCI_TMP"
            log_success "golangci-lint installed"
        fi
    fi

    # addlicense
    if command_exists addlicense && [[ "${UPGRADE}" != "true" ]]; then
        log_success "addlicense already installed"
    else
        log_info "Installing addlicense ${ADDLICENSE_VERSION}..."
        if prompt_continue; then
            go install github.com/google/addlicense@"${ADDLICENSE_VERSION}"
            log_success "addlicense installed"
        fi
    fi

    # go-licenses
    if command_exists go-licenses && [[ "${UPGRADE}" != "true" ]]; then
        log_success "go-licenses already installed"
    else
        log_info "Installing go-licenses ${GO_LICENSES_VERSION}..."
        if prompt_continue; then
            go install github.com/google/go-licenses/v2@"${GO_LICENSES_VERSION}"
            log_success "go-licenses installed"
        fi
    fi

    echo ""
fi

